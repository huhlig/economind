# .env.example — copy to .env and fill in values before running
#
# This file documents all environment variables consumed by Economind.
# Never commit .env to version control — it contains secrets.
# Non-secret settings can also live in economind.toml (see economind.toml.example).

# ── Required secrets ──────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://economind:changeme@localhost:5432/economind

# API key for the Economind REST/WebSocket/GraphQL server
# Generate with: openssl rand -hex 32
ECONOMIND_API_KEY=your-api-key-here

# Docker Compose postgres service credentials (must match DATABASE_URL above)
POSTGRES_USER=economind
POSTGRES_PASSWORD=changeme
POSTGRES_DB=economind

# ── Optional data provider keys ───────────────────────────────────────────────

# FRED (Federal Reserve Economic Data) — register free at https://fred.stlouisfed.org/docs/api/fred/
FRED_API_KEY=

# SimFin fundamentals — register free at https://simfin.com/
SIMFIN_API_KEY=

# ── Optional LLM keys ─────────────────────────────────────────────────────────

# Anthropic API key — enables Claude-powered analysis in the MCP server
# Register at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Non-secret overrides (also configurable in economind.toml) ────────────────

# DuckDB file path (default: :memory: for API, economind.duckdb for CLI)
DUCKDB_PATH=economind.duckdb

# API server bind address
ECONOMIND_BIND=0.0.0.0:8080

# MCP server port
ECONOMIND_MCP_PORT=8081

# Ports exposed by Docker Compose
ECONOMIND_PORT=8080

# Tracing / log level
RUST_LOG=economind=info,tower_http=warn
